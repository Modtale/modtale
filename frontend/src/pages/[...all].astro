---
import BaseLayout from '../layouts/BaseLayout.astro';
import App from '../App';
import { extractId, getProjectUrl } from '../utils/slug';
import { isBotUserAgent } from '../utils/seo';
import { DEFAULT_SEO, ROUTE_SEO } from '../data/seo-constants';
import { generateProjectMeta } from '../utils/meta';
import { generateItemListSchema, generateBreadcrumbSchema, getBreadcrumbsForClassification } from '../utils/schema';

const { all } = Astro.params;
const url = Astro.url;
const path = url.pathname;
const cleanPath = path.replace(/\/$/, "");
const searchParams = url.searchParams;

const API_URL = import.meta.env.PUBLIC_API_URL;

let title = DEFAULT_SEO.title;
let description = DEFAULT_SEO.description;
let keywords = DEFAULT_SEO.keywords;
let image = "https://modtale.net/assets/favicon.svg";
let jsonLd: any = undefined;
let initialData: any = null;

if (ROUTE_SEO[cleanPath]) {
    const seo = ROUTE_SEO[cleanPath];
    title = seo.title;
    description = seo.description;
    if (seo.keywords) keywords = seo.keywords;
}

const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Modtale",
    "url": "https://modtale.net/"
};

if (cleanPath === '' || cleanPath === '/') {
    jsonLd = websiteSchema;
}

const userAgent = Astro.request.headers.get('user-agent') || '';
const isBot = isBotUserAgent(userAgent);
const id = extractId(all || '');

const isProjectRoute = cleanPath.startsWith('/mod/') || cleanPath.startsWith('/modpack/') || cleanPath.startsWith('/world/');

let classification = null;
let isHome = false;

if (cleanPath === '/plugins') classification = 'PLUGIN';
else if (cleanPath === '/modpacks') classification = 'MODPACK';
else if (cleanPath === '/worlds') classification = 'SAVE';
else if (cleanPath === '/art') classification = 'ART';
else if (cleanPath === '/data') classification = 'DATA';
else if (cleanPath === '/mods') classification = 'ALL';
else if (cleanPath === '' || cleanPath === '/') {
    classification = 'ALL';
    isHome = true;
}

const pageParam = searchParams.get('page');
const styleParam = searchParams.get('style');

const isComplex =
    searchParams.has('q') ||
    searchParams.has('tags') ||
    searchParams.has('version') ||
    searchParams.has('minDl') ||
    searchParams.has('minFav') ||
    searchParams.has('date') ||
    (pageParam !== null && parseInt(pageParam, 10) > 0) ||
    (styleParam !== null && styleParam !== 'grid');

function getSecondsUntilNextUpdate() {
    const now = new Date();
    const nextUpdate = new Date(now);
    nextUpdate.setUTCHours(0, 35, 0, 0);

    if (now > nextUpdate) {
        nextUpdate.setUTCDate(nextUpdate.getUTCDate() + 1);
    }

    return Math.max(60, Math.floor((nextUpdate.getTime() - now.getTime()) / 1000));
}

if (classification) {
    const ttl = getSecondsUntilNextUpdate();
    Astro.response.headers.set('Cache-Control', `public, max-age=60, s-maxage=${ttl}, stale-while-revalidate=86400`);

    if (!isComplex) {
        try {
            if (isHome) {
                const [trendingRes, popularRes, gemsRes, relevanceRes, statsRes] = await Promise.allSettled([
                    fetch(`${API_URL}/projects?size=20&sort=trending`),
                    fetch(`${API_URL}/projects?size=20&sort=popular`),
                    fetch(`${API_URL}/projects?category=hidden_gems&size=20&sort=favorites`),
                    fetch(`${API_URL}/projects?size=20&sort=relevance`),
                    fetch(`${API_URL}/analytics/platform/stats`)
                ]);

                const getJson = async (res: any) => res.status === 'fulfilled' && res.value.ok ? await res.value.json() : null;

                const trending = await getJson(trendingRes);
                const popular = await getJson(popularRes);
                const gems = await getJson(gemsRes);
                const relevance = await getJson(relevanceRes);
                const stats = await getJson(statsRes);

                const combined = [
                    ...(trending?.content || []),
                    ...(popular?.content || []),
                    ...(gems?.content || []),
                    ...(relevance?.content || [])
                ];

                const uniqueMap = new Map();
                combined.forEach(m => uniqueMap.set(m.id, m));

                const unique = Array.from(uniqueMap.values()).sort((a, b) => a.id.localeCompare(b.id));

                initialData = {
                    homeMods: unique,
                    stats: stats || { totalProjects: 0, totalDownloads: 0, totalUsers: 0 }
                };
                jsonLd = websiteSchema;

            } else {
                const sort = searchParams.get('sort') || 'relevance';
                const view = searchParams.get('view');

                let categoryParam = '';
                if (view === 'favorites') categoryParam = '&category=Favorites';
                else if (view === 'hidden_gems') categoryParam = '&category=hidden_gems';
                else if (view === 'popular') categoryParam = '&category=popular';
                else if (view === 'trending') categoryParam = '&category=trending';

                const classParam = classification === 'ALL' ? '' : `&classification=${classification}`;
                const endpoint = `${API_URL}/projects?size=12${classParam}&sort=${sort}${categoryParam}`;

                const res = await fetch(endpoint, {
                    headers: { "Cache-Control": "public, s-maxage=300" }
                });

                if (res.ok) {
                    const data = await res.json();
                    initialData = { browseData: data };

                    const items = data.content || [];
                    const listSchema = generateItemListSchema(items);
                    const crumbs = getBreadcrumbsForClassification(classification);
                    const breadcrumbSchema = generateBreadcrumbSchema(crumbs);

                    const schemas = [];
                    if (listSchema) schemas.push(listSchema);
                    if (breadcrumbSchema) schemas.push(breadcrumbSchema);

                    if (schemas.length > 0) jsonLd = schemas;
                }
            }
        } catch (e) {
            console.error("[SSR] List Fetch Error:", e);
        }
    }
}
else if (isBot && id && isProjectRoute) {
    Astro.response.headers.set(
        'Cache-Control',
        'public, max-age=60, s-maxage=600, stale-while-revalidate=86400'
    );

    try {
        const res = await fetch(`${API_URL}/projects/${id}`);

        if (res.ok) {
            const modData = await res.json();

            const canonicalUrl = getProjectUrl(modData);
            if (cleanPath !== canonicalUrl.replace(/\/$/, "")) {
                return Astro.redirect(canonicalUrl, 301);
            }

            initialData = modData;

            const meta = generateProjectMeta(modData);
            if (meta) {
                title = meta.title;
                description = meta.description;
            }

            if (modData.imageUrl) {
                image = modData.imageUrl.startsWith('/api') ? `${API_URL.replace('/api', '')}${modData.imageUrl}` : modData.imageUrl;
            }

            const appSchema = {
                "@context": "https://schema.org",
                "@type": "SoftwareApplication",
                "name": modData.title,
                "description": meta?.description || description,
                "image": image,
                "author": { "@type": "Person", "name": modData.author || 'Unknown' },
                "applicationCategory": "GameApplication",
                "operatingSystem": "Windows, macOS, Linux",
                "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
                "aggregateRating": modData.rating > 0 ? {
                    "@type": "AggregateRating",
                    "ratingValue": modData.rating,
                } : undefined
            };

            const crumbs = getBreadcrumbsForClassification(modData.classification || 'PLUGIN');
            const fullCrumbs = [...crumbs, { name: modData.title, url: canonicalUrl }];
            const breadcrumbSchema = generateBreadcrumbSchema(fullCrumbs);

            jsonLd = [appSchema, breadcrumbSchema];
        }
    } catch (e) {
        console.error("[SSR] Bot Fetch Error:", e);
    }
}
---

<BaseLayout title={title} description={description} keywords={keywords} image={image} jsonLd={jsonLd} initialData={initialData}>
    <App client:load initialPath={path} ssrData={initialData} />
</BaseLayout>