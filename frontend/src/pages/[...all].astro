---
import BaseLayout from '../layouts/BaseLayout.astro';
import App from '../App';
import { SiteRoutes } from '../utils/routes';
import {
    buildCanonicalUrl,
    getRobotsDirective,
    isBotUserAgent,
    isBrowseRoutePath,
    normalizeSeoPath,
} from '../utils/seo';
import { DEFAULT_SEO, ROUTE_SEO, generateDynamicSEO } from '../data/seo-constants';
import { generateProjectMeta } from '../utils/meta';
import {
    generateBreadcrumbSchema,
    generateCollectionPageSchema,
    generateItemListSchema,
    generateOrganizationSchema,
    generateWebsiteSchema,
    getBreadcrumbsForClassification,
} from '../utils/schema';
import { BACKEND_URL } from '@/utils/api.ts';

const { all } = Astro.params;
const url = Astro.url;
const path = url.pathname;
const cleanPath = normalizeSeoPath(path);
const searchParams = url.searchParams;

const routeSeo = ROUTE_SEO[cleanPath];
let title = routeSeo?.title || DEFAULT_SEO.title;
let description = routeSeo?.description || DEFAULT_SEO.description;
let keywords = routeSeo?.keywords || DEFAULT_SEO.keywords;
let jsonLd: any = undefined;
let initialData: any = null;
let ssrSuccessfullyCompleted = false;

const DAY_IN_SECONDS = 60 * 60 * 24;

const fetchJsonWithTimeout = async (resource: string, timeoutMs = 1500, init: RequestInit = {}) => {
    const controller = new AbortController();
    const timeoutHandle = setTimeout(() => controller.abort(), timeoutMs);
    try {
        const response = await fetch(resource, {
            ...init,
            signal: controller.signal,
        });
        if (!response.ok) return null;
        return await response.json();
    } catch {
        return null;
    } finally {
        clearTimeout(timeoutHandle);
    }
};

let canonicalOverride = buildCanonicalUrl(cleanPath, searchParams);
let pageNext = undefined;
let pagePrev = undefined;
let robots = getRobotsDirective(cleanPath, searchParams);

const baseSEO = {
    title: routeSeo?.title || DEFAULT_SEO.title,
    description: routeSeo?.description || DEFAULT_SEO.description,
};

const websiteSchema = generateWebsiteSchema();
const organizationSchema = generateOrganizationSchema();
const collectionPageSchema = routeSeo && (cleanPath === '/' || isBrowseRoutePath(cleanPath))
    ? generateCollectionPageSchema({
        name: routeSeo.h1,
        description: routeSeo.description,
        path: cleanPath,
        keywords: routeSeo.keywords,
        about: routeSeo.keywords.split(',').map((item) => item.trim()).slice(0, 8),
    })
    : null;

const baseSchemas: any[] = [websiteSchema, organizationSchema];
if (collectionPageSchema) baseSchemas.push(collectionPageSchema);

const userAgent = Astro.request.headers.get('user-agent') || '';
const isBot = isBotUserAgent(userAgent);
const identifier = all ? all.split('/').pop() : '';
const projectId = identifier ? SiteRoutes.extractId(identifier) : '';

const isProjectRoute = cleanPath.startsWith('/project/')
    || cleanPath.startsWith('/mod/')
    || cleanPath.startsWith('/modpack/')
    || cleanPath.startsWith('/world/');

let image = (isProjectRoute && identifier)
    ? `${BACKEND_URL}/api/v1/og/project/${projectId}.png`
    : 'https://modtale.net/assets/logo.svg';

let classification = null;
let isHome = false;

if (cleanPath === '/plugins') classification = 'PLUGIN';
else if (cleanPath === '/modpacks') classification = 'MODPACK';
else if (cleanPath === '/worlds') classification = 'SAVE';
else if (cleanPath === '/art') classification = 'ART';
else if (cleanPath === '/data') classification = 'DATA';
else if (cleanPath === '/mods') classification = 'ALL';
else if (cleanPath === '/') {
    classification = 'ALL';
    isHome = true;
}

const pageParamStr = searchParams.get('page') || '0';
const pageNum = parseInt(pageParamStr, 10);
const styleParam = searchParams.get('style') || 'grid';
const sortParam = searchParams.get('sort') || '';
const viewParam = searchParams.get('view') || '';
const qParam = searchParams.get('q') || '';

if (classification && !isHome) {
    const dynamicMeta = generateDynamicSEO(baseSEO, pageNum, sortParam, viewParam, qParam);
    title = dynamicMeta.title;
    description = dynamicMeta.description;

    if (pageNum > 0) {
        const prevParams = new URLSearchParams();
        if (pageNum > 1) prevParams.set('page', String(pageNum - 1));
        pagePrev = buildCanonicalUrl(cleanPath, prevParams);
    }
}

const isComplex =
    searchParams.has('q')
    || searchParams.has('tags')
    || searchParams.has('version')
    || searchParams.has('minDl')
    || searchParams.has('minFav')
    || searchParams.has('date')
    || pageNum > 0
    || styleParam !== 'grid'
    || searchParams.has('view')
    || searchParams.has('sort');

const isBrowseRoute = !!classification && !isHome;
const isStaticBrowseRequest = isBrowseRoute && !isComplex;

if (classification) {
    if (!isComplex || isBot) {
        try {
            if (isHome) {
                const [trending, stats] = await Promise.all([
                    fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects?size=24&sort=trending`),
                    fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/analytics/platform/stats`),
                ]);

                const unique = trending?.content || [];

                initialData = {
                    homeProjects: unique || [],
                    stats: stats || { totalProjects: 0, totalDownloads: 0, totalUsers: 0 },
                };

                const homeListSchema = generateItemListSchema(unique.slice(0, 20));
                const schemas: any[] = [...baseSchemas];
                if (homeListSchema) schemas.push(homeListSchema);
                jsonLd = schemas;

                ssrSuccessfullyCompleted = true;
            } else {
                const sort = searchParams.get('sort') || 'relevance';
                const view = searchParams.get('view');
                const page = searchParams.get('page') || '0';

                let categoryParam = '';
                if (view === 'favorites') categoryParam = '&category=Favorites';
                else if (view === 'hidden_gems') categoryParam = '&category=hidden_gems';
                else if (view === 'popular') categoryParam = '&category=popular';
                else if (view === 'trending') categoryParam = '&category=trending';

                const searchParamStr = qParam ? `&search=${encodeURIComponent(qParam)}` : '';

                const tagsVal = searchParams.get('tags') || '';
                const tagsParamStr = tagsVal ? `&tags=${encodeURIComponent(tagsVal)}` : '';

                const classParam = classification === 'ALL' ? '' : `&classification=${classification}`;
                const endpoint = `${BACKEND_URL}/api/v1/projects?size=12&page=${page}${classParam}&sort=${sort}${categoryParam}${searchParamStr}${tagsParamStr}`;

                const data = await fetchJsonWithTimeout(endpoint, 2000, {
                    headers: { 'Cache-Control': 'public, s-maxage=300' },
                });

                if (data) {
                    initialData = { browseData: data, browseDataReady: true };

                    if (data.totalPages > pageNum + 1) {
                        const nextParams = new URLSearchParams();
                        nextParams.set('page', String(pageNum + 1));
                        pageNext = buildCanonicalUrl(cleanPath, nextParams);
                    }

                    const items = data.content || [];
                    const listSchema = generateItemListSchema(items);
                    const crumbs = getBreadcrumbsForClassification(classification);
                    const breadcrumbSchema = generateBreadcrumbSchema(crumbs);

                    const schemas: any[] = [...baseSchemas];
                    if (listSchema) schemas.push(listSchema);
                    if (breadcrumbSchema) schemas.push(breadcrumbSchema);

                    jsonLd = schemas;
                    ssrSuccessfullyCompleted = true;
                } else {
                    initialData = { browseData: { content: [], totalElements: 0, totalPages: 0 }, browseDataReady: false };
                }
            }
        } catch {
            if (isHome) {
                initialData = { homeProjects: [], stats: { totalProjects: 0, totalDownloads: 0, totalUsers: 0 } };
            } else {
                initialData = { browseData: { content: [], totalElements: 0, totalPages: 0 }, browseDataReady: false };
            }
        }
    } else {
        jsonLd = baseSchemas;
    }
} else if (isBot && identifier && isProjectRoute) {
    try {
        const modData = await fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects/${projectId}`, 2500);

        if (modData) {
            const projectUrl = SiteRoutes.project(modData);
            if (cleanPath !== normalizeSeoPath(projectUrl)) {
                return Astro.redirect(projectUrl, 301);
            }

            initialData = modData;

            const meta = generateProjectMeta(modData);
            if (meta) {
                title = meta.title;
                description = meta.description;
            }

            const appSchema = {
                '@context': 'https://schema.org',
                '@type': 'SoftwareApplication',
                name: modData.title,
                description: meta?.description || description,
                image,
                author: { '@type': 'Person', name: modData.author || 'Unknown' },
                applicationCategory: 'GameApplication',
                operatingSystem: 'Windows, macOS, Linux',
                offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            };

            const crumbs = getBreadcrumbsForClassification(modData.classification || 'PLUGIN');
            const fullCrumbs = [...crumbs, { name: modData.title, url: projectUrl }];
            const breadcrumbSchema = generateBreadcrumbSchema(fullCrumbs);

            const schemas: any[] = [websiteSchema, organizationSchema, appSchema];
            if (breadcrumbSchema) schemas.push(breadcrumbSchema);
            jsonLd = schemas;
            ssrSuccessfullyCompleted = true;
        } else {
            initialData = null;
        }
    } catch {
        initialData = null;
    }
}

if (ssrSuccessfullyCompleted && (isHome || isStaticBrowseRequest)) {
    Astro.response.headers.set('Cache-Control', `public, max-age=300, s-maxage=${DAY_IN_SECONDS}, stale-while-revalidate=${DAY_IN_SECONDS}`);
} else if (ssrSuccessfullyCompleted && isProjectRoute && isBot) {
    Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=600, stale-while-revalidate=3600');
} else {
    Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=0, must-revalidate');
}

const projectBootstrapUrl = !initialData && isProjectRoute && projectId ? `${BACKEND_URL}/api/v1/projects/${projectId}` : undefined;
---

<BaseLayout
    title={title}
    description={description}
    keywords={keywords}
    image={image}
    jsonLd={jsonLd}
    initialData={initialData}
    canonicalOverride={canonicalOverride}
    pageNext={pageNext}
    pagePrev={pagePrev}
    projectBootstrapUrl={projectBootstrapUrl}
    robots={robots}
>
    <App client:load initialPath={path} ssrData={initialData} />
</BaseLayout>
