---
import BaseLayout from '../layouts/BaseLayout.astro';
import App from '../App';
import { SiteRoutes } from '../utils/routes';
import {
    buildCanonicalUrl,
    getRobotsDirective,
    isBotUserAgent,
    isBrowseRoutePath,
    normalizeSeoPath,
} from '../utils/seo';
import { DEFAULT_SEO, ROUTE_SEO, generateDynamicSEO } from '../data/seo-constants';
import { generateProjectMeta } from '../utils/meta';
import {
    generateBreadcrumbSchema,
    generateCollectionPageSchema,
    generateItemListSchema,
    generateOrganizationSchema,
    generateWebsiteSchema,
    getBreadcrumbsForClassification,
} from '../utils/schema';
import { BACKEND_URL } from '@/utils/api.ts';

const url = Astro.url;
const path = url.pathname;
const cleanPath = normalizeSeoPath(path);
const searchParams = url.searchParams;
const statusPageUrl = import.meta.env.PUBLIC_STATUS_URL?.trim() || 'https://status.modtale.net';

if (cleanPath === '/status') {
    return Astro.redirect(statusPageUrl, 302);
}

const routeSeo = ROUTE_SEO[cleanPath];
let title = routeSeo?.title || DEFAULT_SEO.title;
let description = routeSeo?.description || DEFAULT_SEO.description;
let keywords = routeSeo?.keywords || DEFAULT_SEO.keywords;
let jsonLd: any = undefined;
let initialData: any = null;
let ssrSuccessfullyCompleted = false;
let wikiBootstrapMetadataData: any = null;
let wikiBootstrapPageData: any = null;
let wikiBootstrapPageSlug: string = 'home-1';

const DAY_IN_SECONDS = 60 * 60 * 24;
const WIKI_SSR_FAST_PATH_TIMEOUT_MS = 220;

const fetchJsonWithTimeout = async (resource: string, timeoutMs = 1500, init: RequestInit = {}) => {
    const controller = new AbortController();
    const timeoutHandle = setTimeout(() => controller.abort(), timeoutMs);
    try {
        const response = await fetch(resource, {
            ...init,
            signal: controller.signal,
        });
        if (!response.ok) return null;
        return await response.json();
    } catch {
        return null;
    } finally {
        clearTimeout(timeoutHandle);
    }
};

let canonicalOverride = buildCanonicalUrl(cleanPath, searchParams);
let pageNext = undefined;
let pagePrev = undefined;
let robots = getRobotsDirective(cleanPath, searchParams);

const baseSEO = {
    title: routeSeo?.title || DEFAULT_SEO.title,
    description: routeSeo?.description || DEFAULT_SEO.description,
};

const websiteSchema = generateWebsiteSchema();
const organizationSchema = generateOrganizationSchema();
const collectionPageSchema = routeSeo && (cleanPath === '/' || isBrowseRoutePath(cleanPath))
    ? generateCollectionPageSchema({
        name: routeSeo.h1,
        description: routeSeo.description,
        path: cleanPath,
        keywords: routeSeo.keywords,
        about: routeSeo.keywords.split(',').map((item) => item.trim()).slice(0, 8),
    })
    : null;

const baseSchemas: any[] = [websiteSchema, organizationSchema];
if (collectionPageSchema) baseSchemas.push(collectionPageSchema);

const userAgent = Astro.request.headers.get('user-agent') || '';
const isBot = isBotUserAgent(userAgent);
const pathSegments = cleanPath.split('/').filter(Boolean);
const isProjectRoute = pathSegments.length >= 2
    && ['project', 'mod', 'modpack', 'world'].includes(pathSegments[0]);
const wikiSegmentIndex = isProjectRoute ? pathSegments.indexOf('wiki', 2) : -1;
const wikiPagePath = wikiSegmentIndex >= 0 ? pathSegments.slice(wikiSegmentIndex + 1).join('/') : '';
wikiBootstrapPageSlug = wikiPagePath || 'home-1';

const projectRouteKey = isProjectRoute ? SiteRoutes.projectRouteKeyFromPath(cleanPath) : '';
const projectLookupKey = projectRouteKey ? SiteRoutes.extractId(projectRouteKey) : '';
const projectId = projectLookupKey;

let image = (isProjectRoute && projectLookupKey)
    ? `${BACKEND_URL}/api/v1/og/project/${projectLookupKey}.png`
    : 'https://modtale.net/assets/logo.svg';

let classification = null;
let isHome = false;

if (cleanPath === '/plugins') classification = 'PLUGIN';
else if (cleanPath === '/modpacks') classification = 'MODPACK';
else if (cleanPath === '/worlds') classification = 'SAVE';
else if (cleanPath === '/art') classification = 'ART';
else if (cleanPath === '/data') classification = 'DATA';
else if (cleanPath === '/mods') classification = 'ALL';
else if (cleanPath === '/') {
    classification = 'ALL';
    isHome = true;
}

const pageParamStr = searchParams.get('page') || '0';
const pageNum = parseInt(pageParamStr, 10);
const styleParam = searchParams.get('style') || 'grid';
const sortParam = searchParams.get('sort') || '';
const qParam = searchParams.get('q') || '';
const normalizeSort = (sort: string) => (
    sort === 'popular' || sort === 'trending' || sort === 'downloads' || sort === 'favorites' || sort === 'newest' || sort === 'updated'
        ? sort
        : 'relevance'
);

if (classification && !isHome) {
    const dynamicMeta = generateDynamicSEO(baseSEO, pageNum, sortParam, qParam);
    title = dynamicMeta.title;
    description = dynamicMeta.description;

    if (pageNum > 0) {
        const prevParams = new URLSearchParams();
        if (pageNum > 1) prevParams.set('page', String(pageNum - 1));
        pagePrev = buildCanonicalUrl(cleanPath, prevParams);
    }
}

const isComplex =
    searchParams.has('q')
    || searchParams.has('tags')
    || searchParams.has('version')
    || searchParams.has('minDl')
    || searchParams.has('minFav')
    || searchParams.has('date')
    || pageNum > 0
    || styleParam !== 'grid'
    || searchParams.has('sort');

const isBrowseRoute = !!classification && !isHome;
const isStaticBrowseRequest = isBrowseRoute && !isComplex;

if (classification) {
    if (isHome) {
        try {
            const homeRequestInit = {
                headers: { 'Cache-Control': 'public, s-maxage=300, stale-while-revalidate=86400' },
            };
            const [marquee, trending, newest, stats] = await Promise.all([
                fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects?size=16&sort=popular&view=marquee`, 1200, homeRequestInit),
                fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects?size=12&sort=trending`, 1200, homeRequestInit),
                fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects?size=12&sort=newest`, 1200, homeRequestInit),
                fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/analytics/platform/stats`, 1200, homeRequestInit),
            ]);

            const unique = trending?.content || newest?.content || [];
            const marqueeProjects = marquee?.content || [];
            const newestProjects = newest?.content || [];

            initialData = {
                homeDataReady: true,
                homeProjects: unique || [],
                homeMarqueeProjects: marqueeProjects,
                homeTrendingProjects: unique || [],
                homeNewestProjects: newestProjects,
                stats: stats || { totalProjects: 0, totalDownloads: 0, totalUsers: 0 },
            };

            const homeListSchema = generateItemListSchema(unique.slice(0, 20));
            const schemas: any[] = [...baseSchemas];
            if (homeListSchema) schemas.push(homeListSchema);
            jsonLd = schemas;

            ssrSuccessfullyCompleted = true;
        } catch {
            initialData = { homeDataReady: false, homeProjects: [], stats: { totalProjects: 0, totalDownloads: 0, totalUsers: 0 } };
        }
    } else if (isStaticBrowseRequest) {
        try {
                const sort = normalizeSort(searchParams.get('sort') || '');
                const page = searchParams.get('page') || '0';

                const searchParamStr = qParam ? `&search=${encodeURIComponent(qParam)}` : '';

                const tagsVal = searchParams.get('tags') || '';
                const tagsParamStr = tagsVal ? `&tags=${encodeURIComponent(tagsVal)}` : '';

                const classParam = classification === 'ALL' ? '' : `&classification=${classification}`;
                const endpoint = `${BACKEND_URL}/api/v1/projects?size=12&page=${page}${classParam}&sort=${sort}${searchParamStr}${tagsParamStr}`;

                const data = await fetchJsonWithTimeout(endpoint, 2000, {
                    headers: { 'Cache-Control': 'public, s-maxage=300' },
                });

                if (data) {
                    initialData = { browseData: data, browseDataReady: true };

                    if (data.totalPages > pageNum + 1) {
                        const nextParams = new URLSearchParams();
                        nextParams.set('page', String(pageNum + 1));
                        pageNext = buildCanonicalUrl(cleanPath, nextParams);
                    }

                    const items = data.content || [];
                    const listSchema = generateItemListSchema(items);
                    const crumbs = getBreadcrumbsForClassification(classification);
                    const breadcrumbSchema = generateBreadcrumbSchema(crumbs);

                    const schemas: any[] = [...baseSchemas];
                    if (listSchema) schemas.push(listSchema);
                    if (breadcrumbSchema) schemas.push(breadcrumbSchema);

                    jsonLd = schemas;
                    ssrSuccessfullyCompleted = true;
                } else {
                    initialData = { browseData: { content: [], totalElements: 0, totalPages: 0 }, browseDataReady: false };
                }
        } catch {
            initialData = { browseData: { content: [], totalElements: 0, totalPages: 0 }, browseDataReady: false };
        }
    } else {
        jsonLd = baseSchemas;
    }
} else if (isBot && projectLookupKey && isProjectRoute) {
    try {
        const modData = await fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects/${projectLookupKey}`, 2500);

        if (modData) {
            const projectUrl = SiteRoutes.project(modData);
            const canonicalBasePath = normalizeSeoPath(projectUrl);
            const currentBasePath = normalizeSeoPath(SiteRoutes.projectBasePathFromPath(cleanPath));

            if (currentBasePath && currentBasePath !== canonicalBasePath) {
                const canonicalPath = cleanPath.replace(currentBasePath, canonicalBasePath);
                return Astro.redirect(canonicalPath, 301);
            }

            initialData = modData;

            const meta = generateProjectMeta(modData);
            if (meta) {
                title = meta.title;
                description = meta.description;
            }

            const appSchema = {
                '@context': 'https://schema.org',
                '@type': 'SoftwareApplication',
                name: modData.title,
                description: meta?.description || description,
                image,
                author: { '@type': 'Person', name: modData.author || 'Unknown' },
                applicationCategory: 'GameApplication',
                operatingSystem: 'Windows, macOS, Linux',
                offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
            };

            const crumbs = getBreadcrumbsForClassification(modData.classification || 'PLUGIN');
            const fullCrumbs = [...crumbs, { name: modData.title, url: projectUrl }];
            const breadcrumbSchema = generateBreadcrumbSchema(fullCrumbs);

            const schemas: any[] = [websiteSchema, organizationSchema, appSchema];
            if (breadcrumbSchema) schemas.push(breadcrumbSchema);
            jsonLd = schemas;
            ssrSuccessfullyCompleted = true;
        } else {
            initialData = null;
        }
    } catch {
        initialData = null;
    }
}

if (wikiSegmentIndex >= 0 && projectId) {
    const wikiBundlePath = wikiPagePath ? `/_bundle/${wikiPagePath}` : '/_bundle';
    const wikiBundleRequest = fetchJsonWithTimeout(
        `${BACKEND_URL}/api/v1/wiki/${encodeURIComponent(projectId)}${wikiBundlePath}`,
        WIKI_SSR_FAST_PATH_TIMEOUT_MS,
        { headers: { 'Cache-Control': 'public, s-maxage=600, stale-while-revalidate=3600' } }
    );
    const projectRequest = initialData
        ? Promise.resolve(initialData)
        : fetchJsonWithTimeout(`${BACKEND_URL}/api/v1/projects/${projectId}`, WIKI_SSR_FAST_PATH_TIMEOUT_MS);
    const wikiBundleData = await wikiBundleRequest;
    const projectData = initialData
        ? initialData
        : wikiBundleData?.project || await projectRequest;

    if (!initialData && projectData && !(projectData as any).__projectUnavailable) {
        initialData = projectData;

        const meta = generateProjectMeta(projectData);
        if (meta) {
            title = meta.title;
            description = meta.description;
        }

        const projectUrl = SiteRoutes.project(projectData);
        const crumbs = getBreadcrumbsForClassification(projectData.classification || 'PLUGIN');
        const breadcrumbSchema = generateBreadcrumbSchema([...crumbs, { name: projectData.title, url: projectUrl }]);
        if (breadcrumbSchema) {
            jsonLd = [websiteSchema, organizationSchema, breadcrumbSchema];
        }
    }

    if (wikiBundleData?.metadata) {
        wikiBootstrapMetadataData = wikiBundleData.metadata;
    }

    if (wikiBundleData?.page) {
        wikiBootstrapPageData = wikiBundleData.page;
        wikiBootstrapPageSlug = wikiBundleData.pageSlug || wikiBootstrapPageSlug;
    }

    if (initialData || wikiBootstrapPageData) {
        ssrSuccessfullyCompleted = true;
    }
}

if (ssrSuccessfullyCompleted && (isHome || isStaticBrowseRequest)) {
    Astro.response.headers.set('Cache-Control', `public, max-age=300, s-maxage=${DAY_IN_SECONDS}, stale-while-revalidate=${DAY_IN_SECONDS}`);
} else if (ssrSuccessfullyCompleted && wikiSegmentIndex >= 0) {
    Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=600, stale-while-revalidate=3600');
} else if (ssrSuccessfullyCompleted && isProjectRoute && isBot) {
    Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=600, stale-while-revalidate=3600');
} else {
    Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=0, must-revalidate');
}

const projectBootstrapUrl = !initialData && isProjectRoute && projectLookupKey ? `${BACKEND_URL}/api/v1/projects/${projectLookupKey}` : undefined;
const wikiBootstrap = wikiSegmentIndex >= 0 && projectId
    ? {
        projectId,
        bundleUrl: `${BACKEND_URL}/api/v1/wiki/${encodeURIComponent(projectId)}/_bundle${wikiPagePath ? `/${wikiPagePath}` : ''}`,
        metadataUrl: `${BACKEND_URL}/api/v1/wiki/${encodeURIComponent(projectId)}`,
        metadataData: wikiBootstrapMetadataData,
        pageUrl: `${BACKEND_URL}/api/v1/wiki/${encodeURIComponent(projectId)}/${wikiBootstrapPageSlug}`,
        pageSlug: wikiBootstrapPageSlug,
        pageData: wikiBootstrapPageData,
    }
    : undefined;
---

<BaseLayout
    title={title}
    description={description}
    keywords={keywords}
    image={image}
    jsonLd={jsonLd}
    initialData={initialData}
    canonicalOverride={canonicalOverride}
    pageNext={pageNext}
    pagePrev={pagePrev}
    projectBootstrapUrl={projectBootstrapUrl}
    wikiBootstrap={wikiBootstrap}
    robots={robots}
>
    <App client:load initialPath={path} ssrData={initialData} />
</BaseLayout>
