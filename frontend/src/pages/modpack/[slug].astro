---
import BaseLayout from '../../layouts/BaseLayout.astro';
import App from '../../App';
import { SiteRoutes } from '../../utils/routes';
import { generateProjectMeta } from '../../utils/meta';
import { ROUTE_SEO } from '../../data/seo-constants';
import {
    generateOrganizationSchema,
    generateProjectSchemas,
    generateWebsiteSchema,
    getProjectOgImageUrl,
} from '../../utils/schema';
import { BACKEND_URL } from "@/utils/api.ts";

const { slug } = Astro.params;
const path = Astro.url.pathname;
const cleanPath = path.replace(/\/$/, "");
const projectId = slug ? SiteRoutes.extractId(slug) : '';

let modData = null;
let projectUnavailable = false;
let title = ROUTE_SEO['/modpacks'].title;
let description = ROUTE_SEO['/modpacks'].description;
let image = getProjectOgImageUrl(projectId);
let jsonLd: any = undefined;
let ssrSuccessfullyCompleted = false;

if (projectId) {
    const controller = new AbortController();
    const timeoutHandle = setTimeout(() => controller.abort(), 2500);

    try {
        const res = await fetch(`${BACKEND_URL}/api/v1/projects/${projectId}`, {
            signal: controller.signal,
        });
        if (res.ok) {
            modData = await res.json();

            const canonicalUrl = SiteRoutes.project(modData);
            if (cleanPath !== canonicalUrl.replace(/\/$/, "")) {
                return Astro.redirect(canonicalUrl, 301);
            }

            const meta = generateProjectMeta(modData);
            if (meta) {
                title = meta.title;
                description = meta.description;
            }

            jsonLd = [
                generateWebsiteSchema(),
                generateOrganizationSchema(),
                ...generateProjectSchemas(modData),
            ];
            ssrSuccessfullyCompleted = true;
        } else if (res.status === 404 || res.status === 410) {
            projectUnavailable = true;
        }
    } catch (e) {
        projectUnavailable = false;
    } finally {
        clearTimeout(timeoutHandle);
    }
}

if (ssrSuccessfullyCompleted) {
    Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=600, stale-while-revalidate=86400');
} else {
    Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=0, must-revalidate');
}

const projectInitialData = modData || (projectUnavailable && projectId ? { __projectUnavailable: true, id: projectId } : null);
const projectBootstrapUrl = !projectInitialData && projectId ? `${BACKEND_URL}/api/v1/projects/${projectId}` : undefined;
---

<BaseLayout title={title} description={description} image={image} jsonLd={jsonLd} initialData={projectInitialData} projectBootstrapUrl={projectBootstrapUrl}>
    <App client:load initialPath={path} ssrData={projectInitialData} />
</BaseLayout>
