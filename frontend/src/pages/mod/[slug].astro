---
import BaseLayout from '../../layouts/BaseLayout.astro';
import App from '../../App';
import { getProjectUrl } from '../../utils/slug';
import { isBotUserAgent } from '../../utils/seo';
import { generateProjectMeta } from '../../utils/meta';
import { ROUTE_SEO } from '../../data/seo-constants';
import { generateBreadcrumbSchema, getBreadcrumbsForClassification } from '../../utils/schema';
import { BACKEND_URL } from "@/utils/api.ts";

const { slug } = Astro.params;
const path = Astro.url.pathname;
const cleanPath = path.replace(/\/$/, "");

const userAgent = Astro.request.headers.get('user-agent') || '';
const isBot = isBotUserAgent(userAgent);

let modData = null;
let title = ROUTE_SEO['/mods'].title;
let description = ROUTE_SEO['/mods'].description;
let image = slug ? `${BACKEND_URL}/api/v1/og/project/${slug}.png` : "https://modtale.net/assets/favicon.svg";
let jsonLd: any = undefined;
let ssrSuccessfullyCompleted = false;

if (isBot && slug) {
    try {
        const res = await fetch(`${BACKEND_URL}/api/v1/projects/${slug}`);
        if (res.ok) {
            modData = await res.json();

            const canonicalUrl = getProjectUrl(modData);
            if (cleanPath !== canonicalUrl.replace(/\/$/, "")) {
                return Astro.redirect(canonicalUrl, 301);
            }

            const meta = generateProjectMeta(modData);
            if (meta) {
                title = meta.title;
                description = meta.description;
            }

            const appSchema = {
                "@context": "https://schema.org",
                "@type": "SoftwareApplication",
                "name": modData.title,
                "image": modData.imageUrl,
                "author": { "@type": "Person", "name": modData.author || 'Unknown' },
                "applicationCategory": "GameApplication",
                "operatingSystem": "Windows, macOS, Linux",
                "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
                "aggregateRating": (modData.rating && modData.rating > 0) ? {
                    "@type": "AggregateRating",
                    "ratingValue": modData.rating,
                } : undefined
            };

            const crumbs = getBreadcrumbsForClassification('PLUGIN');
            const fullCrumbs = [...crumbs, { name: modData.title, url: canonicalUrl }];
            const breadcrumbSchema = generateBreadcrumbSchema(fullCrumbs);

            jsonLd = [appSchema, breadcrumbSchema];
            ssrSuccessfullyCompleted = true;
        }
    } catch (e) {}
}

if (ssrSuccessfullyCompleted) {
    Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=600, stale-while-revalidate=86400');
} else {
    Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=0, must-revalidate');
}
---

<BaseLayout title={title} image={image} jsonLd={jsonLd} initialData={modData}>
    <App client:load initialPath={path} ssrData={modData} />
</BaseLayout>